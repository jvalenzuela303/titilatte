# =============================================================================
# Minimarket Platform — Variables de Entorno: Staging
# Fase 2
#
# Copia este archivo como .env.staging y rellena los valores reales:
#   cp .env.staging.example .env.staging
#
# Este archivo SE SUMA al .env base — no lo reemplaza.
# Uso con docker compose:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml \
#                  --env-file .env.staging up -d
#
# IMPORTANTE:
#   - .env.staging NUNCA debe subirse al repositorio (.gitignore lo excluye)
#   - Las variables aquí definidas sobreescriben las del .env base
#   - Usa contraseñas distintas a las de desarrollo
# =============================================================================


# =============================================================================
# PostgreSQL — Staging (credenciales distintas a dev)
# =============================================================================

POSTGRES_DB=minimarket_staging
POSTGRES_USER=minimarket_staging_user
POSTGRES_PASSWORD=change_me_staging_password

# URL de conexión del backend al postgres de staging
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/minimarket_staging


# =============================================================================
# Backend — Spring Boot (Staging)
# =============================================================================

# Perfil fijo para staging — NO cambiar (docker-compose.staging.yml lo fuerza también)
SPRING_PROFILES_ACTIVE=staging

# JWT — generar con: openssl rand -base64 64
JWT_SECRET=change_me_staging_jwt_secret
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# JVM — heap conservador para staging (menos recursos que prod)
JAVA_OPTS=-Xms256m -Xmx384m -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp


# =============================================================================
# Staging específico
# =============================================================================

# Nivel de log: WARN reduce ruido; cambiar a INFO para debugging puntual
LOG_LEVEL=WARN

# Directorio de backups automáticos en el host
BACKUP_DIR=/backups/postgres

# Días de retención de backups (30 días = ~30 archivos .dump)
BACKUP_RETENTION_DAYS=30


# =============================================================================
# Nginx
# =============================================================================

# Puerto expuesto al host en staging (puede ser distinto a prod)
NGINX_HTTP_PORT=80


# =============================================================================
# Frontend — React + Vite
# =============================================================================

# URL base de la API para el build del frontend en staging.
# Cambiar por el dominio real de staging cuando exista.
VITE_API_URL=http://staging.minimarket.local/api/v1


# =============================================================================
# Monitoreo — Grafana (stack de monitoring opcional)
# =============================================================================

# Contraseña del usuario admin de Grafana.
# Generar con: openssl rand -base64 20
GRAFANA_ADMIN_PASSWORD=


# =============================================================================
# Fase 2 — Funcionalidades nuevas
# =============================================================================

# Máximo de filas en exportaciones de reportes (CSV/Excel)
REPORT_MAX_EXPORT_ROWS=10000

# Habilita la verificación de crédito al registrar clientes
CREDIT_CHECK_ENABLED=true
