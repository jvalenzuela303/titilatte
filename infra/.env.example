# =============================================================================
# Minimarket Platform — Variables de Entorno
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# IMPORTANTE:
#   - El archivo .env NUNCA debe subirse al repositorio (.gitignore lo excluye)
#   - Usa contraseñas largas y aleatorias en producción
#   - Genera JWT_SECRET con: openssl rand -base64 64
# =============================================================================


# =============================================================================
# PostgreSQL
# =============================================================================

# Nombre de la base de datos principal
POSTGRES_DB=minimarket_db

# Usuario de la base de datos (evitar usar "postgres" por seguridad)
POSTGRES_USER=minimarket_user

# Contraseña del usuario de la base de datos
# Producción: usa al menos 32 caracteres aleatorios
POSTGRES_PASSWORD=change_me_in_production

# Puerto expuesto al host (solo en development override)
POSTGRES_PORT=5432


# =============================================================================
# Backend — Spring Boot 3
# =============================================================================

# URL de conexión JDBC que usa Spring (Flyway y JPA la leen de aquí).
# El hostname "postgres" es el nombre del servicio en docker-compose.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/minimarket_db

# Perfil activo de Spring: dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# ---- JWT ----
# Clave secreta para firmar los tokens JWT (HMAC-SHA256).
# Debe ser una cadena de al menos 256 bits (32 bytes) en Base64.
# Genera una con: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64

# Duración del access token en milisegundos (1 hora = 3600000)
JWT_EXPIRATION=3600000

# Duración del refresh token en milisegundos (24 horas = 86400000)
JWT_REFRESH_EXPIRATION=86400000

# ---- JVM ----
# Opciones de JVM para el contenedor del backend.
# En desarrollo el override agrega el agente JDWP para debugging.
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200


# =============================================================================
# Frontend — React + Vite
# =============================================================================

# URL base de la API que usa el frontend (Axios en axiosInstance.ts).
# En desarrollo con docker-compose apunta a nginx (puerto 80, sin hostname).
# En producción sería https://tu-dominio.com/api/v1
VITE_API_URL=http://localhost/api/v1


# =============================================================================
# Nginx
# =============================================================================

# Puerto HTTP expuesto al host
NGINX_HTTP_PORT=80


# =============================================================================
# Fase 2 - Reportes
# =============================================================================

# Máximo de filas permitidas en exportaciones de reportes (CSV/Excel).
# Previene exports masivos que saturen la memoria del backend.
REPORT_MAX_EXPORT_ROWS=10000


# =============================================================================
# Fase 2 - Crédito
# =============================================================================

# Habilita la verificación de historial crediticio al registrar nuevos clientes.
# Deshabilitar en desarrollo si no hay integración con el servicio de crédito.
CREDIT_CHECK_ENABLED=true
